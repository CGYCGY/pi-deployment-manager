{
  "_about": "Single source of truth for pi-deployment-manager. Copy to config.json (gitignored) and fill in. This is the ONLY place deployment creds live — the manager writes them into each project's gitignored deploy/.env.deploy at deploy time and NEVER commits them, so your projects stop carrying secrets.",

  "stateDir": "~/.pi-deployment-manager",
  "_stateDir_note": "Where the manager writes its logs (<stateDir>/logs/manager.log). The client driver also keeps its session state here.",

  "coolify": {
    "_note": "The one Coolify VPS every project deploys to.",
    "base_url": "https://coolify.example.com",
    "api_token": "CHANGE-ME-coolify-api-token",
    "server_uuid": "CHANGE-ME-coolify-server-uuid",
    "dest_uuid": "CHANGE-ME-coolify-destination-uuid"
  },

  "cloudflare": {
    "_note": "The one Cloudflare zone/domain; every project becomes a subdomain on it.",
    "api_token": "CHANGE-ME-cloudflare-token-dns-edit",
    "zone_id": "CHANGE-ME-cloudflare-zone-id",
    "zone_name": "example.com"
  },

  "registry": {
    "_note": "Where built images are pushed: <ghcr>/<github_org>/<repo>.",
    "github_org": "your-github-org",
    "ghcr": "ghcr.io"
  },

  "convex": {
    "_note": "Convex Cloud (managed, not self-hosted) deploy key. Used backend-first: convex deploy -> capture prod URL -> inject as build-time env into the frontend.",
    "deploy_key": "CHANGE-ME-convex-deploy-key"
  },

  "model": "openai-codex/gpt-5.5",
  "_model_note": "Manager session model; matches the pi-e2e-tester hub. Empty = pi default.",
  "thinking": "high",
  "_thinking_note": "Reasoning tier; matches the pi-e2e-tester hub. Empty = pi default."
}
